generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String             @id @default(cuid())
  display_name               String?
  picture_url                String?
  email                      String?
  role                       String             @default("rider")
  preferred_language         String             @default("ko")
  push_notifications_enabled Boolean            @default(true)
  created_at                 DateTime           @default(now())
  device_push_tokens         DevicePushToken[]
  identities                 UserIdentity[]
  password_credential        PasswordCredential?
  registrations              UserRegistration[]
  scan_events                ScanEvent[]

  @@index([role])
  @@map("users")
}

model UserIdentity {
  id             String    @id @default(cuid())
  user_id        String
  provider       String
  provider_uid   String
  provider_email String?
  email_verified Boolean   @default(false)
  last_login_at  DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())
  user           User      @relation(fields: [user_id], references: [id])

  @@unique([provider, provider_uid])
  @@index([user_id])
  @@index([provider_email])
  @@map("user_identities")
}

model PasswordCredential {
  user_id         String    @id
  email           String    @unique
  password_hash   String
  is_active       Boolean   @default(true)
  failed_attempts Int       @default(0)
  locked_until    DateTime?
  last_login_at   DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now())
  user            User      @relation(fields: [user_id], references: [id])

  @@map("password_credentials")
}

model DevicePushToken {
  id               String   @id @default(cuid())
  user_id          String
  platform         String
  token            String   @unique
  bundle_id        String?
  apns_environment String?
  package_name     String?
  is_active        Boolean  @default(true)
  last_seen_at     DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now())
  user             User     @relation(fields: [user_id], references: [id])

  @@index([user_id, is_active])
  @@map("device_push_tokens")
}

model Route {
  id                       String             @id @default(cuid())
  route_code               String             @unique
  name                     String
  display_name             String?
  line                     String
  service                  String
  direction                String             @default("to_church")
  revision                 String
  google_maps_url          String?
  resolved_google_maps_url String?
  sync_status              String             @default("pending")
  sync_source_hash         String?
  stops_snapshot_hash      String?
  last_synced_at           DateTime?
  sync_error               String?
  path_json                Json?
  path_cache_status        String             @default("missing")
  path_cache_updated_at    DateTime?
  path_cache_expires_at    DateTime?
  path_cache_error         String?
  active                   Boolean            @default(true)
  stops                    RouteStop[]
  runs                     ShuttleRun[]
  registrations            UserRegistration[]

  @@index([active])
  @@index([line, service, revision])
  @@map("routes")
}

model Place {
  id                        String      @id @default(cuid())
  google_place_id           String      @unique
  name                      String
  display_name              String?
  address                   String?
  formatted_address         String?
  primary_type              String?
  primary_type_display_name String?
  lat                       Float
  lng                       Float
  place_types               String[]
  notes                     String?
  is_terminal               Boolean     @default(false)
  stop_id                   String?
  route_stops               RouteStop[]

  @@index([google_place_id])
  @@index([lat, lng])
  @@index([is_terminal])
  @@map("places")
}

model RouteStop {
  id                String             @id @default(cuid())
  route_id          String
  place_id          String
  sequence          Int
  pickup_time       String?
  notes             String?
  is_pickup_enabled Boolean            @default(true)
  active            Boolean            @default(true)
  route             Route              @relation(fields: [route_id], references: [id])
  place             Place              @relation(fields: [place_id], references: [id])
  registrations     UserRegistration[]
  scan_events       ScanEvent[]

  @@unique([route_id, sequence])
  @@unique([route_id, place_id])
  @@index([route_id, sequence])
  @@index([place_id])
  @@index([is_pickup_enabled])
  @@index([active])
  @@map("route_stops")
}

model UserRegistration {
  id            String    @id @default(cuid())
  user_id       String
  route_id      String
  route_stop_id String
  registered_at DateTime  @default(now())
  updated_at    DateTime?
  status        String    @default("active")
  user          User      @relation(fields: [user_id], references: [id])
  route         Route     @relation(fields: [route_id], references: [id])
  route_stop    RouteStop @relation(fields: [route_stop_id], references: [id])

  @@unique([user_id, route_id])
  @@index([status])
  @@map("user_registrations")
}

model ShuttleRun {
  id           String      @id @default(cuid())
  route_id     String
  service_date DateTime
  status       String      @default("scheduled")
  started_at   DateTime?
  ended_at     DateTime?
  created_mode String?
  created_by   String?
  ended_mode   String?
  ended_by     String?
  route        Route       @relation(fields: [route_id], references: [id])
  scan_events  ScanEvent[]

  @@index([route_id, status])
  @@map("shuttle_runs")
}

model ScanEvent {
  id                  String     @id @default(cuid())
  user_id             String
  run_id              String
  route_stop_id       String
  scanned_at          DateTime   @default(now())
  result_code         String
  additional_passengers Int      @default(0)
  idempotency_key     String     @unique
  user                User       @relation(fields: [user_id], references: [id])
  run                 ShuttleRun @relation(fields: [run_id], references: [id])
  route_stop          RouteStop  @relation(fields: [route_stop_id], references: [id])

  @@index([run_id, route_stop_id])
  @@map("scan_events")
}

model Notification {
  id                 String   @id @default(cuid())
  user_id            String
  run_id             String
  trigger_stop_id    String
  stops_away         Int
  title_ko           String
  body_ko            String
  title_en           String
  body_en            String
  is_read            Boolean  @default(false)
  created_at         DateTime @default(now())
  route_code         String?
  user_route_stop_id String?

  @@unique([user_id, run_id, trigger_stop_id])
  @@index([user_id, is_read])
  @@map("notifications")
}

model NotificationDeliveryAttempt {
  id              String   @id @default(cuid())
  notification_id String
  user_id         String
  channel         String
  target_hash     String?
  status          String
  status_code     Int?
  reason          String?
  attempted_at    DateTime @default(now())
  completed_at    DateTime?
  metadata        Json?

  @@index([notification_id])
  @@index([user_id, attempted_at])
  @@index([channel, status])
  @@map("notification_delivery_attempts")
}

model Schedule {
  id           String   @id @default(cuid())
  name         String
  status       String
  created_at   DateTime @default(now())
  created_by   String?
  published_at DateTime?
  published_by String?

  @@index([status])
  @@map("schedules")
}

model ScheduleRoute {
  id            String   @id @default(cuid())
  schedule_id   String
  route_id      String
  stops_snapshot Json
  sync_status   String   @default("pending")
  synced_at     DateTime?
  sync_error    String?

  @@unique([schedule_id, route_id])
  @@index([schedule_id])
  @@map("schedule_routes")
}

model AdminStopOverride {
  run_id                    String
  route_stop_id             String
  status                    String
  total_passengers_override Int?
  set_by                    String?
  set_at                    DateTime @default(now())

  @@id([run_id, route_stop_id])
  @@map("admin_stop_overrides")
}

model AutoRunConfig {
  id           String    @id
  enabled      Boolean   @default(false)
  days_of_week Int[]
  start_time   String
  end_time     String
  updated_at   DateTime?
  updated_by   String?

  @@map("auto_run_config")
}
