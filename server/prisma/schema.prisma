generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RIDER
  DRIVER
  ADMIN
}

enum NotificationType {
  BUS_APPROACHING
}

enum DeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum DeclarationStatus {
  DECLARED
  BOARDED
  NO_SHOW
  CANCELED
}

model User {
  id                   String                @id @default(cuid())
  externalRef          String?               @unique
  name                 String
  role                 UserRole              @default(RIDER)
  notificationOptIn    Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  declarations         BoardingDeclaration[]
  deviceTokens         DeviceToken[]
  scanEvents           ScanEvent[]           @relation("ScanByUser")
  notificationDelivery NotificationDelivery[]
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  token     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model Route {
  id           String                @id @default(cuid())
  code         String                @unique
  name         String
  colorHex     String                @default("#1677ff")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  stops        RouteStop[]
  shuttleRuns  ShuttleRun[]
  declarations BoardingDeclaration[]
}

model Stop {
  id           String                @id @default(cuid())
  code         String                @unique
  name         String
  lat          Decimal               @db.Decimal(10, 7)
  lng          Decimal               @db.Decimal(10, 7)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  routeStops   RouteStop[]
  declarations BoardingDeclaration[]
  scanEvents   ScanEvent[]
  targetNotifications  NotificationDelivery[] @relation("TargetStop")
  triggerNotifications NotificationDelivery[] @relation("TriggerStop")
}

model RouteStop {
  id        String   @id @default(cuid())
  routeId   String
  stopId    String
  sequence  Int
  etaMinute Int?

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop  Stop  @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([routeId, sequence])
  @@unique([routeId, stopId])
  @@index([stopId])
}

model ShuttleRun {
  id            String      @id @default(cuid())
  routeId       String
  vehicleNumber String?
  startedAt     DateTime
  endedAt       DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  route         Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  scanEvents    ScanEvent[]
  notifications NotificationDelivery[]

  @@index([routeId, startedAt])
}

model BoardingDeclaration {
  id         String            @id @default(cuid())
  userId     String
  routeId    String
  stopId     String
  serviceDay DateTime
  status     DeclarationStatus @default(DECLARED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop Stop  @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@index([routeId, serviceDay])
  @@index([userId, serviceDay])
  @@index([stopId, serviceDay])
}

model ScanEvent {
  id              String   @id @default(cuid())
  shuttleRunId    String
  stopId          String
  scannedByUserId String?
  scannedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  shuttleRun ShuttleRun @relation(fields: [shuttleRunId], references: [id], onDelete: Cascade)
  stop       Stop      @relation(fields: [stopId], references: [id], onDelete: Restrict)
  scannedBy  User?     @relation("ScanByUser", fields: [scannedByUserId], references: [id], onDelete: SetNull)

  @@index([shuttleRunId, scannedAt])
}

model NotificationDelivery {
  id             String           @id @default(cuid())
  userId         String
  shuttleRunId   String
  targetStopId   String
  triggerStopId  String
  notificationType NotificationType @default(BUS_APPROACHING)
  title          String
  body           String
  status         DeliveryStatus   @default(QUEUED)
  providerMessageId String?
  errorMessage   String?
  createdAt      DateTime         @default(now())
  sentAt         DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shuttleRun ShuttleRun @relation(fields: [shuttleRunId], references: [id], onDelete: Cascade)
  targetStop Stop      @relation("TargetStop", fields: [targetStopId], references: [id], onDelete: Restrict)
  triggerStop Stop     @relation("TriggerStop", fields: [triggerStopId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([shuttleRunId, targetStopId])
}
