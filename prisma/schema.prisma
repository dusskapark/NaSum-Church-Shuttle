generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String             @id @default(cuid())
  display_name  String?
  picture_url   String?
  role          String             @default("rider")
  created_at    DateTime           @default(now())
  identities    UserIdentity[]
  registrations UserRegistration[]
  scan_events   ScanEvent[]
}

model UserIdentity {
  id           String   @id @default(cuid())
  user_id      String
  provider     String
  provider_uid String
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id])

  @@unique([provider, provider_uid])
}

model Route {
  id                       String             @id @default(cuid())
  route_code               String             @unique
  name                     String
  display_name             String?
  line                     String
  service                  String
  direction                String             @default("to_church")
  revision                 String
  google_maps_url          String?
  resolved_google_maps_url String?
  sync_status              String             @default("pending")
  sync_source_hash         String?
  stops_snapshot_hash      String?
  last_synced_at           DateTime?
  sync_error               String?
  path_json                Json?
  path_cache_status        String             @default("missing")
  path_cache_updated_at    DateTime?
  path_cache_expires_at    DateTime?
  path_cache_error         String?
  active                   Boolean            @default(true)
  stops                    RouteStop[]
  runs                     ShuttleRun[]
  registrations            UserRegistration[]

  @@index([active])
  @@index([line, service, revision])
}

model Place {
  id              String    @id @default(cuid())
  google_place_id String    @unique
  name            String
  display_name    String?
  address         String?
  lat             Float
  lng             Float
  place_types     String[]
  notes           String?
  is_terminal     Boolean   @default(false)
  route_stops     RouteStop[]

  @@index([google_place_id])
  @@index([lat, lng])
  @@index([is_terminal])
}

model RouteStop {
  id                String             @id @default(cuid())
  route_id          String
  place_id          String
  sequence          Int
  pickup_time       String?
  notes             String?
  is_pickup_enabled Boolean            @default(true)
  route             Route              @relation(fields: [route_id], references: [id])
  place             Place              @relation(fields: [place_id], references: [id])
  registrations     UserRegistration[]
  scan_events       ScanEvent[]

  @@unique([route_id, sequence])
  @@unique([route_id, place_id])
  @@index([route_id, sequence])
  @@index([place_id])
  @@index([is_pickup_enabled])
}

model UserRegistration {
  id            String    @id @default(cuid())
  user_id       String
  route_id      String
  route_stop_id String
  registered_at DateTime  @default(now())
  status        String    @default("active")
  user          User      @relation(fields: [user_id], references: [id])
  route         Route     @relation(fields: [route_id], references: [id])
  route_stop    RouteStop @relation(fields: [route_stop_id], references: [id])

  @@unique([user_id, route_id])
}

model ShuttleRun {
  id           String      @id @default(cuid())
  route_id     String
  service_date DateTime
  status       String      @default("scheduled")
  route        Route       @relation(fields: [route_id], references: [id])
  scan_events  ScanEvent[]
}

model ScanEvent {
  id              String     @id @default(cuid())
  user_id         String
  run_id          String
  route_stop_id   String
  scanned_at      DateTime   @default(now())
  result_code     String
  idempotency_key String     @unique
  user            User       @relation(fields: [user_id], references: [id])
  run             ShuttleRun @relation(fields: [run_id], references: [id])
  route_stop      RouteStop  @relation(fields: [route_stop_id], references: [id])
}
