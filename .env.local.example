# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# Optional alias for local Neon serverless usage
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# Optional: only needed for Prisma schema changes or migrations
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# App URLs / LIFF
NEXT_PUBLIC_APP_URL=https://example.vercel.app
NEXT_PUBLIC_LIFF_ENDPOINT_URL=https://example.vercel.app
NEXT_PUBLIC_LIFF_ID=YOUR_LIFF_ID
# Optional: localhost development LIFF ID override
NEXT_PUBLIC_LIFF_ID_DEV=YOUR_DEV_LIFF_ID

# LINE Login / Messaging
LINE_LOGIN_CHANNEL_ID=YOUR_LINE_LOGIN_CHANNEL_ID
LINE_LOGIN_CHANNEL_SECRET=YOUR_LINE_LOGIN_CHANNEL_SECRET
LINE_UNIVERSAL_LINK_URL=
LINE_ANDROID_PACKAGE_NAME=
LINE_ANDROID_DEBUG_SIGNATURE_SHA1=
LINE_ANDROID_URL_SCHEME=
MESSAGING_API_CHANNEL_ACCESS_TOKEN=YOUR_MESSAGING_API_CHANNEL_ACCESS_TOKEN
MESSAGING_API_CHANNEL_ID=YOUR_MESSAGING_API_CHANNEL_ID
MESSAGING_API_CHANNEL_SECRET=YOUR_MESSAGING_API_CHANNEL_SECRET

# Server secrets
CRON_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
# Optional: if omitted, LINE_LOGIN_CHANNEL_SECRET is used for session signing.
# SESSION_SECRET=CHANGE_ME_TO_AT_LEAST_32_CHARACTERS

# OAuth / native clients
APPLE_CLIENT_ID=sg.nasumchurch.shuttle
APPLE_BUNDLE_ID=sg.nasumchurch.shuttle
GOOGLE_CLIENT_ID=YOUR_GOOGLE_SERVER_CLIENT_ID
GOOGLE_SERVER_CLIENT_ID=YOUR_GOOGLE_SERVER_CLIENT_ID
GOOGLE_IOS_CLIENT_ID=YOUR_GOOGLE_IOS_CLIENT_ID
GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.YOUR_GOOGLE_IOS_CLIENT_ID
GOOGLE_ANDROID_CLIENT_ID=YOUR_GOOGLE_ANDROID_CLIENT_ID
GOOGLE_ANDROID_PACKAGE_NAME=YOUR_ANDROID_PACKAGE_NAME
GOOGLE_ANDROID_SHA256_CERT_FINGERPRINTS=SHA256:FINGERPRINT
GOOGLE_AUTH_CLIENT_IDS=YOUR_GOOGLE_SERVER_CLIENT_ID,YOUR_GOOGLE_IOS_CLIENT_ID,YOUR_GOOGLE_ANDROID_CLIENT_ID

# Apple review email admin
APPLE_REVIEW_ADMIN_EMAIL=review-admin@example.com
APPLE_REVIEW_ADMIN_PASSWORD=CHANGE_ME_FOR_APP_REVIEW_ONLY
APPLE_REVIEW_ADMIN_NAME=Apple Review Admin

# Maps
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_BROWSER_GOOGLE_MAPS_API_KEY

# APNs
APNS_BUNDLE_ID=org.example.NaSumShuttle
APNS_ENVIRONMENT=sandbox
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_PRIVATE_KEY_BASE64=BASE64_ENCODED_P8_CONTENTS
